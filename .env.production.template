# Production Environment Variables Template
# Copy this to .env.production and fill in your Railway values

# =====================================
# API SERVER (apps/api/.env.production)
# =====================================
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://postgres:password@host:5432/saferoute
REDIS_URL=redis://default:password@host:6379
JWT_SECRET=generate_32_char_random_string_here
JWT_REFRESH_SECRET=generate_different_32_char_random_string_here
CLIENT_URL=https://your-admin.up.railway.app

# =====================================
# ADMIN PANEL (apps/admin/.env.production)
# =====================================
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app/api

# =====================================
# GPS SERVICE (apps/gps-service/.env.production)
# =====================================
NODE_ENV=production
PORT=3002
TIMESCALEDB_URL=postgresql://postgres:password@host:5432/saferoute
REDIS_URL=redis://default:password@host:6379
JWT_SECRET=use_same_as_api_jwt_secret

# =====================================
# HOW TO GENERATE SECRETS:
# Run in PowerShell:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Run this 2 times for JWT_SECRET and JWT_REFRESH_SECRET
# =====================================
